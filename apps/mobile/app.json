{
  "expo": {
    "name": "DatumPro Field",
    "slug": "datumpro-field",
    "scheme": "datumpro",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "DatumPro uses your photos to attach site evidence to tasks.",
          "cameraPermission": "DatumPro uses the camera to capture site photos for tasks."
        }
      ],
      "expo-notifications"
    ],
    "ios": { "supportsTablet": true },
    "android": { "package": "app.datumpro.field" }
  }
}
