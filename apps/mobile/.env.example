# DatumPro Field — public config (Expo inlines EXPO_PUBLIC_* into the JS bundle).
#
# Copy this file to apps/mobile/.env and fill in the values (the same URL + anon
# key that live in eas.json's build profiles — they're the *publishable* Supabase
# credentials, not secrets).
#
#   cp .env.example .env
#
# Why a local .env matters:
#   • `eas build`  reads these from the eas.json build profile — a .env isn't
#     strictly needed for builds.
#   • `eas update` (OTA) does NOT read eas.json's build env, so it needs these
#     values here (or in EAS environment variables). Without them, the OTA
#     bundle ships with an empty Supabase config and the app can't sign in.
#   • `expo start` (local dev) reads .env too.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key
