# ── DatumPro web (apps/web) — environment ────────────────────────────────────
# Copy to `.env.local` for local dev, or paste these into Vercel → Project →
# Settings → Environment Variables for production. NEXT_PUBLIC_* are exposed to
# the browser; everything else is server-only — never expose the service role
# key or Resend key to the client.

# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL + anon/publishable key from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Bypasses RLS — used by cron jobs and admin paths. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (required) ───────────────────────────────────────────────────────
# Canonical origin, used in emails and links. In prod use your Vercel/custom
# domain, e.g. https://app.datumpro.com. Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email — Resend (required for invites & notifications) ────────────────────
# API key from resend.com. FROM must be on a domain you've verified in Resend.
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=DatumPro <no-reply@yourdomain.com>

# ── Cron (required in prod) ──────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` to /api/cron/*. The
# routes refuse to run when this is unset, so set a long random value in prod.
CRON_SECRET=generate-a-long-random-string

# ── Web push (optional — enables the notification bell) ──────────────────────
# Public half of the VAPID key pair. The private half is a Supabase Edge
# Function secret (see DEPLOY.md), not a web env var.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ── Error reporting — Sentry (optional) ──────────────────────────────────────
# Leave blank to disable. NEXT_PUBLIC_ is the browser DSN; SENTRY_DSN the server.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
