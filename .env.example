# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, NEVER exposed to the client

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── SMS (Africa's Talking) ──────────────────────────────────────────────────
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# ─── Payments (Paynow — USD) ─────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=                  # server webhook for payment results
PAYNOW_RETURN_URL=                  # browser return after payment

# ─── Scheduled jobs (Vercel Cron) ────────────────────────────────────────────
# Shared secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET`.
# The /api/cron/* routes refuse to run without it. Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Mission Control adapter (cross-product command center) ──────────────────
# Shared secret Mission Control sends as `Authorization: Bearer $ADMIN_ADAPTER_SECRET`
# to the /api/admin/* routes (org roster + member enable/disable). Those routes use
# the service-role client, so without this secret set they refuse every request.
# Must match MC_DATUMPRO_ADAPTER_SECRET in Mission Control. Generate: openssl rand -hex 32
ADMIN_ADAPTER_SECRET=

# ─── Background jobs (Inngest — reserved, not yet wired) ──────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Errors (Sentry) ─────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Web Push (chat notifications) ───────────────────────────────────────────
# Generate with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=       # public key — safe for the client
# The private key + shared secret live as Supabase *function* secrets, not here:
#   VAPID_PRIVATE_KEY, VAPID_SUBJECT, CHAT_PUSH_SECRET, APP_URL
# See supabase/functions/chat-push/README.md

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
